generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  author_id        String    @db.Uuid
  content          String?
  media_ids        String[]  @db.VarChar(255)
  visibility       String?   @default("friends") @db.VarChar(20)
  is_shared        Boolean?  @default(false)
  original_post_id String?   @db.Uuid
  like_count       Int?      @default(0)
  comment_count    Int?      @default(0)
  share_count      Int?      @default(0)
  type             String?   @default("post") @db.VarChar(20)
  view_count       Int?      @default(0)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @db.Timestamptz(6)

  // Relations
  original_post    Post?     @relation("SharedPosts", fields: [original_post_id], references: [id])
  shared_posts     Post[]    @relation("SharedPosts")
  likes            Like[]
  comments         Comment[]

  @@index([author_id], map: "idx_posts_author_id")
  @@index([created_at(sort: Desc)], map: "idx_posts_created_at")
  @@map("posts")
}

model Like {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  post_id    String   @db.Uuid
  user_id    String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)

  post       Post     @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@unique([post_id, user_id])
  @@index([post_id], map: "idx_likes_post_id")
  @@map("likes")
}

model Comment {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  post_id    String   @db.Uuid
  author_id  String   @db.Uuid
  content    String
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  post       Post     @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@index([post_id], map: "idx_comments_post_id")
  @@map("comments")
}
