# ==============================================
# SocialHub — Environment Variables
# Copy this file to .env and fill in the values
# ==============================================

# --- General ---
COMPOSE_PROJECT_NAME=socialhub
ENVIRONMENT=development

# --- JWT ---
JWT_SECRET=your-jwt-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- PostgreSQL ---
PG_HOST=pg
PG_PORT=5432
PG_DATABASE=socialhub
PG_USER=socialhub
PG_PASSWORD=socialhub_secret

# --- MongoDB ---s
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DATABASE=socialhub
MONGO_USER=socialhub
MONGO_PASSWORD=socialhub_secret
MONGO_URI=mongodb://socialhub:socialhub_secret@mongo:27017/socialhub?authSource=admin

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# --- MinIO (S3-compatible) ---
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=socialhub_minio
MINIO_SECRET_KEY=socialhub_minio_secret
MINIO_BUCKET=socialhub-media
MINIO_USE_SSL=false
MINIO_PRESIGNED_URL_TTL=900

# --- Service Ports (host:container) ---
FRONTEND_PORT=3000
GATEWAY_PORT=8080
USER_SERVICE_PORT=5001
FRIEND_SERVICE_PORT=5002
POST_SERVICE_PORT=5003
CHAT_SERVICE_PORT=5004
MEDIA_SERVICE_PORT=5005
NOTIFICATION_SERVICE_PORT=5006

# --- Service Internal URLs (Docker Compose DNS) ---
USER_SERVICE_URL=http://user-service:5000
FRIEND_SERVICE_URL=http://friend-service:5000
POST_SERVICE_URL=http://post-service:5000
CHAT_SERVICE_URL=http://chat-service:5000
MEDIA_SERVICE_URL=http://media-service:5000
NOTIFICATION_SERVICE_URL=http://notification-service:5000

# --- API Gateway ---
GATEWAY_SECRET=your-gateway-secret

# --- Upload Limits ---
MAX_FILE_SIZE=10485760
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp
